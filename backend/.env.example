# Tellaro PM Backend - Development Environment
# Copy to .env and adjust as needed.
# Resolution order: Docker/K8s Secrets > ENV (.env) > Defaults

# Environment
ENV_ENVIRONMENT=development

# API Server
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=8000
API_SERVER_RELOAD=true
API_WORKERS=1
API_BACKEND_CORS_ORIGINS=*

# OpenSearch (run: docker compose up -d)
OPENSEARCH_HOST=http://localhost:9200
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=
OPENSEARCH_USE_SSL=false
OPENSEARCH_INDEX_PREFIX=
OPENSEARCH_NUMBER_OF_SHARDS=1
OPENSEARCH_NUMBER_OF_REPLICAS=0

# Redis (optional — disable if not running)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_ENABLED=false

# Auth — default provider for domains without explicit config
AUTH_PROVIDER=local

# GitHub OAuth (optional — for user login via GitHub)
# AUTH_GITHUB_CLIENT_ID=
# AUTH_GITHUB_CLIENT_SECRET=
# AUTH_GITHUB_ORG=

# GitHub App (server-to-server — for reading repos, issues, syncing)
# See docs/GITHUB_APP_SETUP.md for setup instructions
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_WEBHOOK_SECRET=

# OIDC (optional — Okta, Azure AD, Keycloak, etc.)
# AUTH_OIDC_DISCOVERY_URL=
# AUTH_OIDC_CLIENT_ID=
# AUTH_OIDC_CLIENT_SECRET=

# JWT — MUST set for sessions to survive backend restarts
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_JWT_SECRET_KEY=change-me-to-a-random-string
# AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=15
# AUTH_REFRESH_TOKEN_EXPIRE_DAYS=30
# AUTH_MAX_DEVICE_SESSIONS=10
# AUTH_RATE_LIMIT_WINDOW=900
# AUTH_RATE_LIMIT_MAX=15

# Local admin bootstrap
AUTH_DEFAULT_ADMIN_USERNAME=admin
AUTH_DEFAULT_ADMIN_EMAIL=admin@localhost.dev
AUTH_DEFAULT_ADMIN_PASSWORD=Admin1234!

# Logging
LOG_LOG_LEVEL=DEBUG
LOG_LOG_TO_STDOUT=true

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:5173
