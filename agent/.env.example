# Tellaro Agent - Development Environment
# Copy to .env and adjust as needed.
# Resolution order: CLI args > Docker/K8s Secrets > ENV (.env) > Defaults

# Backend connection
BACKEND_URL=ws://localhost:8000/ws/agent
BACKEND_API_URL=http://localhost:8000

# Agent identity (required)
AGENT_NAME=my-dev-agent
AGENT_TOKEN=

# Claude Code
CLAUDE_EXECUTABLE=claude

# Logging
LOG_LOG_LEVEL=DEBUG
LOG_LOG_TO_STDOUT=true

# Heartbeat
HEARTBEAT_INTERVAL_SECONDS=30
